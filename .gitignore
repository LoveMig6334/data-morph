# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDEs
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Data (don't commit large/raw data)
data/raw/*
data/processed/*
data/interim/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/interim/.gitkeep

# Models (often too large for git)
models/*
!models/.gitkeep

# Secrets / env
.env
.env.*
!.env.example

# Logs
*.log
logs/

# MLflow / experiment tracking
mlruns/
wandb/
